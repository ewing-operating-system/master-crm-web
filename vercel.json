{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    },
    "api/letters/send-to-lob.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
